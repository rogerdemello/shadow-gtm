# ── Bright Data ───────────────────────────────────────────────────────────
# API token from Bright Data dashboard → Account settings → API tokens.
BRIGHTDATA_API_TOKEN=

# Zone names you created in the Bright Data dashboard (Proxies & Scraping Infra).
# Web Unlocker zone — used to fetch competitor pricing / homepage / careers pages.
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1
# SERP API zone — used for news / buying-intent search signals.
BRIGHTDATA_SERP_ZONE=serp_api1

# Scraping Browser CDP endpoint — used to render JS-heavy / interactive sites
# (mark a competitor "JS-heavy" in the UI to route it here). Copy the full
# wss://... connection string from your Scraping Browser zone in the dashboard.
# Leave empty to disable rendering (Web Unlocker still handles everything else).
BRIGHTDATA_BROWSER_WS=

# ── Anthropic (Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional override. Defaults to claude-opus-4-7 (best reasoning).
# For a snappier live demo (many calls per scan), claude-sonnet-4-6 is ~2x faster.
ANTHROPIC_MODEL=claude-opus-4-7
# Thinking depth + token spend: low | medium | high | max. Default medium.
ANTHROPIC_EFFORT=medium

# ── App ───────────────────────────────────────────────────────────────────
# Set to "1" to run scans against built-in sample HTML instead of the live web
# (handy for offline UI work / demos without burning credits).
SHADOW_GTM_MOCK=0
