# ── Bright Data ───────────────────────────────────────────────────────────
# API token from Bright Data dashboard → Account settings → API tokens.
BRIGHTDATA_API_TOKEN=

# Zone names you created in the Bright Data dashboard (Proxies & Scraping Infra).
# Web Unlocker zone — used to fetch competitor pricing / homepage / careers pages.
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1
# SERP API zone — used for news / buying-intent search signals.
BRIGHTDATA_SERP_ZONE=serp_api1

# Scraping Browser CDP endpoint — used to render JS-heavy / interactive sites
# (mark a competitor "JS-heavy" in the UI to route it here). Copy the full
# wss://... connection string from your Scraping Browser zone in the dashboard.
# Leave empty to disable rendering (Web Unlocker still handles everything else).
BRIGHTDATA_BROWSER_WS=

# ── Google Gemini ─────────────────────────────────────────────────────────
# API key from Google AI Studio → https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override. Defaults to gemini-2.5-flash (fast + cheap, great for live
# demos). Use gemini-2.5-pro for deeper reasoning at higher latency/cost.
GEMINI_MODEL=gemini-2.5-flash
# Optional thinking-budget cap in tokens. Unset = model decides dynamically.
# Set 0 to disable thinking for the snappiest live demo.
GEMINI_THINKING_BUDGET=

# ── Supabase (Postgres + Auth + Realtime) ──────────────────────────────────
# Create a project at https://supabase.com, then copy these from
# Project Settings → API. The URL + anon key are public (inlined into the client
# bundle); the service-role key is a server-only secret — never expose it.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────
# Set to "1" to run scans against built-in sample HTML instead of the live web
# (handy for offline UI work / demos without burning credits).
SHADOW_GTM_MOCK=0

# Optional: structured-log verbosity (debug|info|warn|error) and Sentry DSN.
# LOG_LEVEL=info
# SENTRY_DSN=
